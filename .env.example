# Contact form endpoint for frontend (optional).
# By default the app uses /.netlify/functions/contact.
# Set this only if you want to use a different backend URL.
# VITE_CONTACT_FORM_ENDPOINT=https://api.example.com/contact

# Netlify Function (contact) environment variables
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=info@digio.es
# Must be a verified sender/domain in Resend
CONTACT_FROM_EMAIL=Digio Contact <noreply@digio.es>

# Optional anti-spam tuning for Netlify Function
# CONTACT_RATE_LIMIT_MAX=6
# CONTACT_RATE_LIMIT_WINDOW_MS=600000
# CONTACT_MIN_FILL_MS=2000
